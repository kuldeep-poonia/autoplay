{
  "manifest_version": 3,
  "name": "AutoApply",
  "version": "1.0.0",
  "description": "Universal Job Application Chrome Extension",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*",
    "*://*.wellfound.com/*",
    "*://*.internshala.com/*",
    "*://*.shine.com/*",
    "*://*.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://*.myworkdayjobs.com/*",
    "*://*.icims.com/*"
  ],
  "background": {
    "service_worker": "background_url_monitor.js"
  },
  "action": {
    "default_popup": "activation_menu.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
